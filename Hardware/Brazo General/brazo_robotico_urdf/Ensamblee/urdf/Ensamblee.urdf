<?xml version="1.0" encoding="utf-8"?>
<robot name="Ensamblee">

  <link name="world"/>
  <joint name="fixed_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.035133 0.0010982 0.059578" rpy="0 0 0" />
      <mass value="1.6222" />
      <inertia ixx="0.0057091" ixy="0.00016017" ixz="-1.9562E-07" iyy="0.0078069" iyz="7.9795E-07" izz="0.01293" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/base_link.STL" /></geometry>
      <material name="gris_azulado"><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <link name="base_giratoria">
    <inertial>
      <origin xyz="-0.00012545 -0.0015041 0.14037" rpy="0 0 0" />
      <mass value="0.27811" />
      <inertia ixx="0.00049658" ixy="-4.0519E-06" ixz="-2.3048E-07" iyy="0.00045443" iyz="-3.5467E-06" izz="0.00066548" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/base_giratoria.STL" /></geometry>
      <material name="blanco"><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/base_giratoria.STL" /></geometry>
    </collision>
  </link>
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" /><child link="base_giratoria" /><axis xyz="0 0 1" />
    <limit lower="-3.14" upper="3.14" effort="100" velocity="3.14" />
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <link name="brazo_inferior">
    <inertial>
      <origin xyz="0.10277 -0.010539 0.0045472" rpy="0 0 0" />
      <mass value="0.41319" />
      <inertia ixx="0.00031344" ixy="0.00016033" ixz="4.1036E-05" iyy="0.0018606" iyz="-4.2071E-06" izz="0.0017287" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/brazo_inferior.STL" /></geometry>
      <material name="gris_azulado"><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/brazo_inferior.STL" /></geometry>
    </collision>
  </link>
  <joint name="joint_2" type="revolute">
    <origin xyz="0.00032733 0.0034847 0.1945" rpy="1.6645 -1.5708 0" />
    <parent link="base_giratoria" /><child link="brazo_inferior" /><axis xyz="0 0 -1" />
    <limit lower="-1.57" upper="1.57" effort="100" velocity="3.14" />
    <dynamics damping="15.0" friction="2.0"/>
  </joint>

  <link name="brazo_superior">
    <inertial>
      <origin xyz="0.049945 -0.003032 0.0023765" rpy="0 0 0" />
      <mass value="0.13139" />
      <inertia ixx="2.7543E-05" ixy="6.4343E-06" ixz="1.1157E-05" iyy="0.00016188" iyz="-6.8148E-07" izz="0.00016442" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/brazo_superior.STL" /></geometry>
      <material name="gris_azulado"><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/brazo_superior.STL" /></geometry>
    </collision>
  </link>
  <joint name="joint_3" type="revolute">
    <origin xyz="0.17906 -0.018361 0.00076231" rpy="0 0 -1.5708" />
    <parent link="brazo_inferior" /><child link="brazo_superior" /><axis xyz="0 0 -1" />
    <limit lower="-1.57" upper="1.57" effort="100" velocity="3.14" />
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <link name="ensamblaje_corto">
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="model://Ensamblee/meshes/ensamblaje_corto.STL" /></geometry>
      <material name="gris_oscuro"><color rgba="0.3 0.3 0.3 1" /></material>
    </visual>
    <collision>
      <geometry><mesh filename="model://Ensamblee/meshes/ensamblaje_corto.STL" /></geometry>
    </collision>
  </link>
  <joint name="joint_corto" type="fixed">
    <origin xyz="0.125 0 0" rpy="0 0 0" />
    <parent link="brazo_superior" /><child link="ensamblaje_corto" />
  </joint>

  <link name="dedo_1">
    <visual><geometry><mesh filename="model://Ensamblee/meshes/dedo_1.STL"/></geometry><material name="blanco"/></visual>
  </link>
  <joint name="joint_4" type="revolute">
    <origin xyz="0.03 -0.01 0.01" rpy="2.25 0 0" /><parent link="ensamblaje_corto" /><child link="dedo_1" /><axis xyz="0 0 1" /><limit lower="0" upper="0.5" effort="10" velocity="1" />
  </joint>

  <link name="dedo_2">
    <visual><geometry><mesh filename="model://Ensamblee/meshes/dedo_2.STL"/></geometry><material name="blanco"/></visual>
  </link>
  <joint name="joint_5" type="revolute">
    <origin xyz="0.03 -0.01 -0.01" rpy="-1.94 0 0" /><parent link="ensamblaje_corto" /><child link="dedo_2" /><axis xyz="0 0 1" /><limit lower="0" upper="0.5" effort="10" velocity="1" />
  </joint>

  <link name="dedo_3">
    <visual><geometry><mesh filename="model://Ensamblee/meshes/dedo_3.STL"/></geometry><material name="blanco"/></visual>
  </link>
  <joint name="joint_6" type="revolute">
    <origin xyz="0.03 0.02 0" rpy="0.15 0 0" /><parent link="ensamblaje_corto" /><child link="dedo_3" /><axis xyz="0 0 1" /><limit lower="0" upper="0.5" effort="10" velocity="1" />
  </joint>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <joint_name>joint_1</joint_name><joint_name>joint_2</joint_name><joint_name>joint_3</joint_name>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint_1</joint_name><topic>/model/Ensamblee/joint/joint_1/cmd_pos</topic>
      <p_gain>1000</p_gain><d_gain>50</d_gain> </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint_2</joint_name><topic>/model/Ensamblee/joint/joint_2/cmd_pos</topic>
      <p_gain>2000</p_gain><d_gain>100</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>joint_3</joint_name><topic>/model/Ensamblee/joint/joint_3/cmd_pos</topic>
      <p_gain>1000</p_gain><d_gain>50</d_gain>
    </plugin>
  </gazebo>

</robot>
